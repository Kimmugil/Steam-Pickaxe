# ──────────────────────────────────────────────────────────────────
#  secrets.toml.example
#  이 파일을 복사해서 .streamlit/secrets.toml 로 저장한 뒤 실제 값을 채우세요.
#  secrets.toml 은 .gitignore 에 등록되어 있어 GitHub에 올라가지 않습니다.
# ──────────────────────────────────────────────────────────────────

# ── Google Drive 폴더 ID ───────────────────────────────────────────
# 리뷰 시트들을 저장할 Google Drive 폴더의 ID
GDRIVE_FOLDER_ID = "여기에_폴더_ID_입력"

# ── Gemini API 키 ─────────────────────────────────────────────────
# Google AI Studio (https://aistudio.google.com) 에서 발급
GEMINI_API_KEY = "여기에_GEMINI_API_키_입력"

# ── Steam API 키 (선택) ───────────────────────────────────────────
# https://steamcommunity.com/dev/apikey 에서 발급 (없어도 기본 기능 동작)
STEAM_API_KEY = ""

# ── Google 서비스 계정 ────────────────────────────────────────────
# Google Cloud Console → IAM → 서비스 계정 → 키 → JSON 다운로드 후
# 아래 [GOOGLE_SERVICE_ACCOUNT] 섹션에 각 필드를 복사해 넣으세요.
#
# ※ private_key의 줄바꿈은 \n 으로 유지하세요 (TOML 문자열 내 이스케이프)

[GOOGLE_SERVICE_ACCOUNT]
type                        = "service_account"
project_id                  = "steam-pickaxe"
private_key_id              = "여기에_private_key_id"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n여기에_키_내용\n-----END RSA PRIVATE KEY-----\n"
client_email                = "steam-pickaxe@steam-pickaxe.iam.gserviceaccount.com"
client_id                   = "여기에_client_id"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "여기에_client_x509_cert_url"
universe_domain             = "googleapis.com"
