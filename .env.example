# ════════════════════════════════════════════════════════════════
#  .env.example  ·  실제 값을 채워서 .env 파일로 저장하세요
#  이 파일 자체는 깃허브에 올려도 안전합니다 (값이 없으므로)
# ════════════════════════════════════════════════════════════════

# ── Google 서비스 계정 ────────────────────────────────────────
# 발급 방법: Google Cloud Console → IAM 및 관리 → 서비스 계정
#            → 키 생성 → JSON 다운로드 → 내용을 한 줄 문자열로 압축
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Sheets ──────────────────────────────────────────────
# MASTER_SPREADSHEET: setup_sheets.py 실행 후 출력되는 ID
MASTER_SPREADSHEET_ID=your_master_spreadsheet_id_here

# ── Google Drive 폴더 ID ──────────────────────────────────────
# RAW_REVIEWS 파일이 저장될 드라이브 폴더
# Google Drive → 해당 폴더 URL의 마지막 부분
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ── Gemini API ────────────────────────────────────────────────
# 발급 방법: https://aistudio.google.com/ → Get API key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Steam API (선택사항) ──────────────────────────────────────
# 없어도 공개 API는 동작하지만 있으면 속도 향상
# 발급 방법: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# ── GitHub Personal Access Token ─────────────────────────────
# 게임 등록/이벤트 등록 시 GitHub Actions 자동 트리거에 사용
# 발급 방법: GitHub → Settings → Developer settings → Personal access tokens
#            → Generate new token → repo 권한 선택
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=Kimmugil/Steam-Pickaxe
