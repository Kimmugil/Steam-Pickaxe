# ──────────────────────────────────────────────────────
#  .env.example  ·  실제 값을 채워서 .env 파일로 저장하세요
#  이 파일 자체는 깃허브에 올려도 안전합니다 (값이 없으므로)
# ──────────────────────────────────────────────────────

# Google 서비스 계정 JSON (한 줄로 압축된 문자열)
# Google Cloud Console → 서비스 계정 → 키 생성 → JSON 복사
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Drive 폴더 ID (리뷰 아카이브 & 타임라인 데이터 저장 위치)
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Gemini API 키 (Google AI Studio에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# Steam API 키 (선택 — 없어도 공개 API는 동작함)
# https://steamcommunity.com/dev/apikey 에서 발급
STEAM_API_KEY=your_steam_api_key_here
